root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{cs,csproj,props,targets,xml,resx,config}]
indent_size = 4

[*.{sln,slnx}]
end_of_line = crlf
indent_size = 4

[*.{ps1,psm1,psd1,bat,cmd}]
end_of_line = crlf
indent_size = 4

[*.sh]
end_of_line = lf
indent_size = 2

[*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml,css,scss,html,cshtml}]
indent_size = 2

[.githooks/*]
end_of_line = lf
indent_size = 2
