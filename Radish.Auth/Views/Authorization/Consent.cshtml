@model Radish.Auth.Models.ConsentViewModel
@using System
@using System.Globalization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<Radish.Auth.Resources.Errors> Localizer

@{
    ViewData["Title"] = Localizer["auth.consent.title"];

    var displayClientName = string.IsNullOrWhiteSpace(Model.ClientName) ? Model.ClientId : Model.ClientName;
    var hasClientDescription = !string.IsNullOrWhiteSpace(Model.ClientDescription);
    var applicationDescription = hasClientDescription ? Model.ClientDescription : string.Empty;
    var developerName = string.IsNullOrWhiteSpace(Model.DeveloperName) ? "Radish" : Model.DeveloperName;
    var redirectTarget = string.IsNullOrWhiteSpace(Model.RedirectHost) ? Model.RedirectUri : Model.RedirectHost;
    var redirectDisplay = string.IsNullOrWhiteSpace(redirectTarget)
        ? Localizer["auth.consent.requestingApp"].Value
        : redirectTarget;
    var loginIdentity = string.IsNullOrWhiteSpace(User?.Identity?.Name) ? Localizer["auth.consent.currentAccount"].Value : User!.Identity!.Name!;
    var clientInitial = string.IsNullOrWhiteSpace(displayClientName) ? "R" : displayClientName.Trim()[..1].ToUpperInvariant();
    var permissionCountLabel = Localizer[
        Model.Scopes.Count == 1 ? "auth.consent.permissionCount.one" : "auth.consent.permissionCount.other",
        Model.Scopes.Count];

    var pageEyebrow = Localizer["auth.consent.pageEyebrow"];
    var targetLabel = Localizer["auth.consent.targetLabel"];
    var headingText = Localizer["auth.consent.headingText", displayClientName];
    var heroCopy = Localizer["auth.consent.heroCopy", loginIdentity, redirectDisplay];
    var identityTitle = Localizer["auth.consent.identityTitle"];
    var identityHint = Localizer["auth.consent.identityHint"];
    var accountLabel = Localizer["auth.consent.accountLabel"];
    var appLabel = Localizer["auth.consent.appLabel"];
    var developerLabel = Localizer["auth.consent.developerLabel"];
    var redirectLabel = Localizer["auth.consent.redirectLabel"];
    var permissionTitle = Localizer["auth.consent.permissionTitle"];
    var permissionHint = Localizer["auth.consent.permissionHint"];
    var safetyTitle = Localizer["auth.consent.safetyTitle"];
    var safetyPoint1 = Localizer["auth.consent.safetyPoint1"];
    var safetyPoint2 = Localizer["auth.consent.safetyPoint2"];
    var riskHint = Localizer["auth.consent.riskHint"];
    var decisionHint = Localizer["auth.consent.decisionHint"];
    var technicalTitle = Localizer["auth.consent.technicalTitle"];
    var technicalHint = Localizer["auth.consent.technicalHint"];
    var clientIdLabel = Localizer["auth.consent.clientIdLabel"];
    var redirectUriLabel = Localizer["auth.consent.redirectUriLabel"];
    var rawScopeLabel = Localizer["auth.consent.rawScopeLabel"];

    (string Title, string Description) DescribeScope(string scope)
    {
        return scope switch
        {
            "openid" => (Localizer["auth.consent.scope.openid.title"].Value, Localizer["auth.consent.scope.openid.description"].Value),
            "profile" => (Localizer["auth.consent.scope.profile.title"].Value, Localizer["auth.consent.scope.profile.description"].Value),
            "offline_access" => (Localizer["auth.consent.scope.offlineAccess.title"].Value, Localizer["auth.consent.scope.offlineAccess.description"].Value),
            "radish-api" => (Localizer["auth.consent.scope.radishApi.title"].Value, Localizer["auth.consent.scope.radishApi.description"].Value),
            _ => (Localizer["auth.consent.scope.additional.title"].Value, Localizer["auth.consent.scope.additional.description"].Value)
        };
    }
}

<!DOCTYPE html>
<html lang="@(CultureInfo.CurrentUICulture.Name)">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
        :root {
            color-scheme: light;
            --paper-base: #f5efe6;
            --paper-surface: #fffdf8;
            --paper-muted: #f0e7db;
            --line-soft: #d9cbb9;
            --line-faint: rgba(217, 203, 185, 0.62);
            --ink-strong: #2f2a25;
            --ink-base: #67594d;
            --ink-muted: #8b7a6b;
            --brand: #b24057;
            --brand-deep: #8f3144;
            --brand-soft: #f3dce3;
            --success: #4f9c83;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            min-height: 100svh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 28px 16px;
            background: linear-gradient(180deg, #f7f1e8 0%, #fbfaf6 54%, #f8fafc 100%);
            color: var(--ink-strong);
            font-family: 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
        }

        .display-serif {
            font-family: Georgia, 'Times New Roman', 'Songti SC', 'STSong', serif;
            letter-spacing: 0;
        }

        .consent-shell {
            width: min(100%, 720px);
        }

        .consent-card {
            border: 1px solid rgba(217, 203, 185, 0.86);
            border-radius: 8px;
            background: rgba(255, 253, 248, 0.97);
            box-shadow: 0 22px 54px rgba(47, 42, 37, 0.12);
            overflow: hidden;
        }

        .card-accent {
            height: 6px;
            background: linear-gradient(90deg, var(--brand) 0%, #c78b74 58%, var(--success) 100%);
        }

        .card-body {
            display: grid;
            gap: 22px;
            padding: 30px 32px 34px;
        }

        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 14px;
        }

        .brand-mark {
            display: flex;
            align-items: center;
            gap: 10px;
            min-width: 0;
        }

        .brand-icon {
            width: 36px;
            height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex: 0 0 auto;
            border-radius: 8px;
            background: var(--brand);
            color: #ffffff;
            font-weight: 900;
        }

        .brand-copy {
            display: grid;
            gap: 2px;
            min-width: 0;
        }

        .eyebrow {
            margin: 0;
            color: var(--brand);
            font-size: 0.72rem;
            font-weight: 800;
            letter-spacing: 0;
            text-transform: uppercase;
        }

        .brand-name {
            margin: 0;
            color: var(--ink-muted);
            font-size: 0.78rem;
            font-weight: 700;
        }

        .lang-switcher {
            display: inline-flex;
            align-items: center;
            gap: 3px;
            padding: 3px;
            flex: 0 0 auto;
            border-radius: 999px;
            background: #ffffff;
            border: 1px solid var(--line-soft);
        }

        .lang-button {
            min-height: 28px;
            padding: 5px 10px;
            background: transparent;
            color: var(--ink-base);
            border: none;
            border-radius: 999px;
            cursor: pointer;
            font-size: 12px;
            font-weight: 800;
            transition: background 0.18s ease, color 0.18s ease;
        }

        .lang-button:hover,
        .lang-button.active {
            background: var(--ink-strong);
            color: #ffffff;
        }

        .hero {
            display: grid;
            gap: 12px;
            padding-top: 2px;
        }

        .target-row {
            display: flex;
            align-items: center;
            gap: 12px;
            min-width: 0;
        }

        .app-badge {
            width: 50px;
            height: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex: 0 0 auto;
            border-radius: 8px;
            overflow: hidden;
            background: var(--brand);
            color: #ffffff;
            font-size: 1.2rem;
            font-weight: 900;
            box-shadow: 0 10px 22px rgba(178, 64, 87, 0.2);
        }

        .app-badge img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .target-copy {
            display: grid;
            gap: 4px;
            min-width: 0;
        }

        .target-label {
            color: var(--ink-muted);
            font-size: 0.78rem;
            font-weight: 800;
        }

        h1 {
            margin: 0;
            color: var(--ink-strong);
            font-size: 1.86rem;
            line-height: 1.16;
        }

        .target-description {
            margin: 0;
            color: var(--ink-base);
            font-size: 0.94rem;
            line-height: 1.62;
        }

        .summary-card,
        .permission-card,
        .risk-card,
        .technical-details {
            border: 1px solid var(--line-faint);
            border-radius: 8px;
            background: #ffffff;
        }

        .summary-card {
            display: grid;
            gap: 10px;
            overflow: hidden;
            padding: 16px;
            background: var(--paper-muted);
        }

        .summary-heading {
            display: grid;
            gap: 4px;
        }

        .summary-row {
            display: grid;
            grid-template-columns: 112px minmax(0, 1fr);
            gap: 12px;
            align-items: center;
            min-height: 32px;
        }

        .summary-label {
            color: var(--ink-muted);
            font-size: 0.76rem;
            font-weight: 800;
        }

        .summary-value {
            color: var(--ink-strong);
            font-size: 0.9rem;
            font-weight: 800;
            line-height: 1.38;
            word-break: break-word;
        }

        .section-title {
            display: block;
            margin: 0;
            color: var(--ink-strong);
            font-size: 0.95rem;
            font-weight: 900;
            line-height: 1.35;
        }

        .section-copy {
            margin: 0;
            color: var(--ink-base);
            font-size: 0.84rem;
            line-height: 1.52;
        }

        .permission-card {
            padding: 18px;
        }

        .permission-head {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 10px;
        }

        .count-chip {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 26px;
            padding: 4px 9px;
            flex: 0 0 auto;
            border-radius: 999px;
            background: var(--brand-soft);
            color: var(--brand);
            border: 1px solid #e4c0ca;
            font-size: 0.76rem;
            font-weight: 900;
            white-space: nowrap;
        }

        .scope-list {
            list-style: none;
            padding: 0;
            margin: 0;
            display: grid;
            gap: 14px;
        }

        .scope-item {
            display: grid;
            grid-template-columns: 26px minmax(0, 1fr);
            gap: 10px;
            align-items: start;
        }

        .scope-mark {
            width: 26px;
            height: 26px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: #f8edf1;
            color: var(--brand);
            font-size: 0.9rem;
            font-weight: 900;
        }

        .scope-body {
            min-width: 0;
        }

        .scope-title {
            margin: 0 0 2px;
            color: var(--ink-strong);
            font-size: 0.92rem;
            line-height: 1.36;
        }

        .scope-description {
            margin: 0;
            color: var(--ink-base);
            line-height: 1.45;
            font-size: 0.82rem;
        }

        .risk-card {
            padding: 14px 16px;
            background: #fffaf5;
        }

        .risk-list {
            margin: 8px 0 0;
            padding-left: 18px;
            color: var(--ink-base);
            font-size: 0.83rem;
            line-height: 1.52;
        }

        .risk-list li + li {
            margin-top: 4px;
        }

        .risk-copy {
            margin-top: 9px;
        }

        .technical-details {
            color: var(--ink-base);
            overflow: hidden;
        }

        .technical-details summary {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            min-height: 42px;
            padding: 10px 14px;
            cursor: pointer;
            color: var(--ink-strong);
            font-weight: 900;
            list-style: none;
        }

        .technical-details summary::-webkit-details-marker {
            display: none;
        }

        .technical-details summary::after {
            content: '+';
            display: inline-flex;
            width: 24px;
            height: 24px;
            align-items: center;
            justify-content: center;
            flex: 0 0 auto;
            border-radius: 999px;
            background: var(--paper-muted);
            color: var(--brand);
            border: 1px solid var(--line-soft);
        }

        .technical-details[open] summary::after {
            content: '-';
        }

        .technical-content {
            display: grid;
            gap: 9px;
            padding: 0 14px 14px;
        }

        .technical-hint {
            margin: 0;
            color: var(--ink-muted);
            font-size: 0.8rem;
            line-height: 1.5;
        }

        .technical-grid {
            display: grid;
            gap: 7px;
        }

        .technical-row {
            display: grid;
            gap: 4px;
            padding: 8px 10px;
            border-radius: 8px;
            background: var(--paper-muted);
            border: 1px solid rgba(217, 203, 185, 0.68);
        }

        .technical-label {
            color: var(--ink-muted);
            font-size: 0.72rem;
            font-weight: 800;
        }

        .technical-value {
            color: var(--ink-base);
            font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', monospace;
            font-size: 0.73rem;
            line-height: 1.4;
            word-break: break-all;
        }

        .decision-form {
            display: grid;
            gap: 12px;
            margin-top: 2px;
            padding-top: 18px;
            border-top: 1px solid var(--line-faint);
        }

        .decision-copy {
            margin: 0;
            color: var(--ink-base);
            font-size: 0.82rem;
            line-height: 1.5;
            text-align: center;
        }

        .button-group {
            display: grid;
            gap: 14px;
        }

        .action-button {
            min-height: 52px;
            width: 100%;
            padding: 11px 15px;
            border-radius: 999px;
            font-size: 14px;
            font-weight: 900;
            cursor: pointer;
            transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
        }

        .action-button.primary {
            border: none;
            background: var(--brand);
            color: #ffffff;
            box-shadow: 0 12px 24px rgba(178, 64, 87, 0.2);
        }

        .action-button.primary:hover {
            transform: translateY(-1px);
            background: var(--brand-deep);
            box-shadow: 0 16px 26px rgba(178, 64, 87, 0.25);
        }

        .action-button.secondary {
            border: 1px solid var(--line-soft);
            background: #ffffff;
            color: var(--ink-strong);
        }

        .action-button.secondary:hover {
            background: #f8f4ed;
        }

        @@media (min-width: 720px) {
            .scope-list {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .button-group {
                grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
            }

            .action-button.secondary {
                order: 2;
            }
        }

        @@media (max-width: 640px) {
            body {
                align-items: flex-start;
                padding: 12px;
                background: var(--paper-base);
            }

            .card-body {
                gap: 18px;
                padding: 18px 16px 22px;
            }

            .topbar {
                align-items: flex-start;
                gap: 10px;
            }

            .brand-name {
                display: none;
            }

            .lang-button {
                min-height: 26px;
                padding: 4px 8px;
            }

            .target-row {
                align-items: flex-start;
            }

            .app-badge {
                width: 44px;
                height: 44px;
            }

            .target-description {
                font-size: 0.9rem;
            }

            h1 {
                font-size: 1.5rem;
            }

            .summary-row {
                grid-template-columns: 96px minmax(0, 1fr);
                gap: 8px;
            }

            .permission-card,
            .risk-card {
                padding: 14px;
            }

            .permission-head {
                align-items: center;
            }

            .decision-copy {
                text-align: left;
            }

            .decision-form {
                padding-top: 16px;
            }
        }
    </style>
</head>
<body>
    <main class="consent-shell" aria-label="@pageEyebrow">
        <section class="consent-card">
            <div class="card-accent" aria-hidden="true"></div>
            <div class="card-body">
                <header class="topbar">
                    <div class="brand-mark">
                        <div class="brand-icon">R</div>
                        <div class="brand-copy">
                            <p class="eyebrow">@pageEyebrow</p>
                            <p class="brand-name">Radish Auth</p>
                        </div>
                    </div>

                    <div class="lang-switcher" aria-label="Language">
                        <button type="button" class="lang-button @(CultureInfo.CurrentUICulture.Name.StartsWith("zh", StringComparison.OrdinalIgnoreCase) ? "active" : "")" onclick="switchLanguage('zh')">中文</button>
                        <button type="button" class="lang-button @(CultureInfo.CurrentUICulture.Name.StartsWith("en", StringComparison.OrdinalIgnoreCase) ? "active" : "")" onclick="switchLanguage('en')">English</button>
                    </div>
                </header>

                <section class="hero" aria-label="@targetLabel">
                    <div class="target-row">
                        <div class="app-badge">
                            @if (!string.IsNullOrWhiteSpace(Model.ClientLogo))
                            {
                                <img src="@Model.ClientLogo" alt="@displayClientName" />
                            }
                            else
                            {
                                <span>@clientInitial</span>
                            }
                        </div>

                        <div class="target-copy">
                            <span class="target-label">@targetLabel</span>
                            <h1 class="display-serif">@headingText</h1>
                        </div>
                    </div>

                    <p class="target-description">@heroCopy</p>
                    @if (hasClientDescription)
                    {
                        <p class="target-description">@applicationDescription</p>
                    }
                </section>

                <section class="summary-card" aria-label="@identityTitle">
                    <div class="summary-heading">
                        <strong class="section-title">@identityTitle</strong>
                        <p class="section-copy">@identityHint</p>
                    </div>
                    <div class="summary-row">
                        <span class="summary-label">@accountLabel</span>
                        <span class="summary-value">@loginIdentity</span>
                    </div>
                    <div class="summary-row">
                        <span class="summary-label">@appLabel</span>
                        <span class="summary-value">@displayClientName</span>
                    </div>
                    <div class="summary-row">
                        <span class="summary-label">@developerLabel</span>
                        <span class="summary-value">@developerName</span>
                    </div>
                    <div class="summary-row">
                        <span class="summary-label">@redirectLabel</span>
                        <span class="summary-value">@(string.IsNullOrWhiteSpace(redirectTarget) ? "-" : redirectTarget)</span>
                    </div>
                </section>

                <section class="permission-card" aria-label="@permissionTitle">
                    <div class="permission-head">
                        <div>
                            <strong class="section-title">@permissionTitle</strong>
                            <p class="section-copy">@permissionHint</p>
                        </div>
                        <span class="count-chip">@permissionCountLabel</span>
                    </div>

                    <ul class="scope-list">
                        @foreach (var scope in Model.Scopes)
                        {
                            var scopeInfo = DescribeScope(scope);

                            <li class="scope-item">
                                <span class="scope-mark" aria-hidden="true">✓</span>
                                <div class="scope-body">
                                    <h2 class="scope-title">@scopeInfo.Title</h2>
                                    <p class="scope-description">@scopeInfo.Description</p>
                                </div>
                            </li>
                        }
                    </ul>
                </section>

                <section class="risk-card" aria-label="@safetyTitle">
                    <strong class="section-title">@safetyTitle</strong>
                    <ul class="risk-list">
                        <li>@safetyPoint1</li>
                        <li>@safetyPoint2</li>
                    </ul>
                    <p class="section-copy risk-copy">@riskHint</p>
                </section>

                <details class="technical-details">
                    <summary>@technicalTitle</summary>
                    <div class="technical-content">
                        <p class="technical-hint">@technicalHint</p>
                        <div class="technical-grid">
                            <div class="technical-row">
                                <span class="technical-label">@clientIdLabel</span>
                                <span class="technical-value">@Model.ClientId</span>
                            </div>
                            <div class="technical-row">
                                <span class="technical-label">@redirectUriLabel</span>
                                <span class="technical-value">@Model.RedirectUri</span>
                            </div>
                            <div class="technical-row">
                                <span class="technical-label">@rawScopeLabel</span>
                                <span class="technical-value">@Model.Scope</span>
                            </div>
                        </div>
                    </div>
                </details>

                <form class="decision-form" method="post">
                    <input type="hidden" name="client_id" value="@Model.ClientId" />
                    <input type="hidden" name="redirect_uri" value="@Model.RedirectUri" />
                    <input type="hidden" name="response_type" value="@Model.ResponseType" />
                    <input type="hidden" name="scope" value="@Model.Scope" />
                    <input type="hidden" name="state" value="@Model.State" />

                    <p class="decision-copy">@decisionHint</p>

                    <div class="button-group">
                        <button class="action-button primary" type="submit" name="decision" value="accept">@Localizer["auth.consent.allow"]</button>
                        <button class="action-button secondary" type="submit" name="decision" value="deny">@Localizer["auth.consent.deny"]</button>
                    </div>
                </form>
            </div>
        </section>
    </main>

    <script>
        function switchLanguage(culture) {
            const returnUrl = new URL(window.location.href);
            returnUrl.searchParams.delete('culture');
            returnUrl.searchParams.delete('ui-culture');
            const localReturnUrl = `${returnUrl.pathname}${returnUrl.search}${returnUrl.hash}`;
            const switchUrl = new URL('@Url.Action("SetLanguage", "Account")', window.location.origin);
            switchUrl.searchParams.set('culture', culture);
            switchUrl.searchParams.set('returnUrl', localReturnUrl);
            window.location.assign(switchUrl.toString());
        }
    </script>
</body>
</html>
