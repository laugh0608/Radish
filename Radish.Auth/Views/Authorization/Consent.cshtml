@model Radish.Auth.Models.ConsentViewModel
@using System
@using System.Globalization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<Radish.Auth.Resources.Errors> Localizer

@{
    ViewData["Title"] = Localizer["auth.consent.title"];

    var isZh = CultureInfo.CurrentUICulture.Name.StartsWith("zh", StringComparison.OrdinalIgnoreCase);
    var displayClientName = string.IsNullOrWhiteSpace(Model.ClientName) ? Model.ClientId : Model.ClientName;
    var hasClientDescription = !string.IsNullOrWhiteSpace(Model.ClientDescription);
    var applicationDescription = hasClientDescription ? Model.ClientDescription : string.Empty;
    var developerName = string.IsNullOrWhiteSpace(Model.DeveloperName) ? "Radish" : Model.DeveloperName;
    var redirectTarget = string.IsNullOrWhiteSpace(Model.RedirectHost) ? Model.RedirectUri : Model.RedirectHost;
    var loginIdentity = string.IsNullOrWhiteSpace(User?.Identity?.Name) ? (isZh ? "当前登录账号" : "Current account") : User!.Identity!.Name!;
    var clientInitial = string.IsNullOrWhiteSpace(displayClientName) ? "R" : displayClientName.Trim()[..1].ToUpperInvariant();
    var accountInitial = string.IsNullOrWhiteSpace(loginIdentity) ? "R" : loginIdentity.Trim()[..1].ToUpperInvariant();
    var permissionCountLabel = isZh
        ? $"{Model.Scopes.Count} 项权限"
        : $"{Model.Scopes.Count} permission{(Model.Scopes.Count == 1 ? string.Empty : "s")}";

    var pageEyebrow = isZh ? "Radish 安全授权" : "Radish secure authorization";
    var targetLabel = isZh ? "授权给" : "Authorize";
    var appLabel = isZh ? "应用" : "Application";
    var developerLabel = isZh ? "开发方" : "Developer";
    var redirectLabel = isZh ? "返回到" : "Return to";
    var accountTitle = isZh ? "当前账号" : "Current account";
    var accountHint = isZh
        ? "将以该账号完成授权。不是你的账号时，请取消授权后切换。"
        : "This account will be used. If it is not yours, cancel and switch accounts.";
    var permissionTitle = isZh ? "将获取以下权限" : "Access requested";
    var permissionHint = isZh
        ? "只授予本次请求包含的范围。"
        : "Only the scopes included in this request will be granted.";
    var riskTitle = isZh ? "确认前检查" : "Before you continue";
    var riskPoint1 = isZh ? "应用名称、开发方和返回位置应与你刚才打开的页面一致。" : "The app, developer, and return destination should match the page you opened.";
    var riskPoint2 = isZh ? "如果你不认识这个应用，或当前账号不正确，请取消授权。" : "If you do not recognize this app or the account is wrong, cancel authorization.";
    var decisionHint = isZh ? "允许后将返回应用继续操作；取消不会退出 Radish，也不会修改账号状态。" : "Allowing returns you to the app; cancelling will not sign you out or change your account.";
    var technicalTitle = isZh ? "技术信息" : "Technical details";
    var technicalHint = isZh ? "用于排障和安全核对，普通确认时无需优先阅读。" : "For troubleshooting and security review. You do not need these details for normal confirmation.";
    var scopeCodeLabel = isZh ? "技术范围" : "Scope";
    var clientIdLabel = isZh ? "Client ID" : "Client ID";
    var redirectUriLabel = isZh ? "完整回调地址" : "Full redirect URI";
    var rawScopeLabel = isZh ? "原始 scope" : "Raw scope";

    (string Title, string Description) DescribeScope(string scope)
    {
        return scope switch
        {
            "openid" => isZh
                ? ("确认你的登录身份", "建立安全登录会话。")
                : ("Confirm your signed-in identity", "Establishes a secure sign-in session."),
            "profile" => isZh
                ? ("读取你的基础资料", "显示昵称、头像等基础资料。")
                : ("Read your basic profile", "Shows profile basics such as display name and avatar."),
            "offline_access" => isZh
                ? ("保持登录状态", "减少短时间内重复登录。")
                : ("Maintain your session", "Reduces repeated sign-ins for a short period."),
            "radish-api" => isZh
                ? ("访问 Radish 服务", "继续当前应用中的受保护任务。")
                : ("Access Radish services", "Continues protected tasks in this application."),
            _ => isZh
                ? ("附加访问权限", "该应用声明的额外访问范围。")
                : ("Additional access", "An extra scope declared by this app.")
        };
    }
}

<!DOCTYPE html>
<html lang="@(CultureInfo.CurrentUICulture.Name)">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
        :root {
            color-scheme: light;
            --paper-base: #f5efe6;
            --paper-surface: #fffdf8;
            --paper-muted: #f0e7db;
            --line-soft: #d9cbb9;
            --line-faint: rgba(217, 203, 185, 0.62);
            --ink-strong: #2f2a25;
            --ink-base: #67594d;
            --ink-muted: #8b7a6b;
            --brand: #b24057;
            --brand-deep: #8f3144;
            --brand-soft: #f3dce3;
            --blue: #435c74;
            --success: #4f9c83;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            min-height: 100svh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 28px 16px;
            background: linear-gradient(180deg, #f7f1e8 0%, #fbfaf6 54%, #f8fafc 100%);
            color: var(--ink-strong);
            font-family: 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
        }

        .display-serif {
            font-family: Georgia, 'Times New Roman', 'Songti SC', 'STSong', serif;
            letter-spacing: 0;
        }

        .consent-shell {
            width: min(100%, 640px);
        }

        .consent-card {
            border: 1px solid rgba(217, 203, 185, 0.86);
            border-radius: 8px;
            background: rgba(255, 253, 248, 0.97);
            box-shadow: 0 22px 54px rgba(47, 42, 37, 0.12);
            overflow: hidden;
        }

        .card-accent {
            height: 6px;
            background: linear-gradient(90deg, var(--brand) 0%, #c78b74 58%, var(--success) 100%);
        }

        .card-body {
            display: grid;
            gap: 16px;
            padding: 22px;
        }

        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 14px;
        }

        .brand-mark {
            display: flex;
            align-items: center;
            gap: 10px;
            min-width: 0;
        }

        .brand-icon {
            width: 36px;
            height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex: 0 0 auto;
            border-radius: 8px;
            background: var(--brand);
            color: #ffffff;
            font-weight: 900;
        }

        .brand-copy {
            display: grid;
            gap: 2px;
            min-width: 0;
        }

        .eyebrow {
            margin: 0;
            color: var(--brand);
            font-size: 0.72rem;
            font-weight: 800;
            letter-spacing: 0;
            text-transform: uppercase;
        }

        .brand-name {
            margin: 0;
            color: var(--ink-muted);
            font-size: 0.78rem;
            font-weight: 700;
        }

        .lang-switcher {
            display: inline-flex;
            align-items: center;
            gap: 3px;
            padding: 3px;
            flex: 0 0 auto;
            border-radius: 999px;
            background: #ffffff;
            border: 1px solid var(--line-soft);
        }

        .lang-button {
            min-height: 28px;
            padding: 5px 10px;
            background: transparent;
            color: var(--ink-base);
            border: none;
            border-radius: 999px;
            cursor: pointer;
            font-size: 12px;
            font-weight: 800;
            transition: background 0.18s ease, color 0.18s ease;
        }

        .lang-button:hover,
        .lang-button.active {
            background: var(--ink-strong);
            color: #ffffff;
        }

        .hero {
            display: grid;
            gap: 10px;
            padding-top: 2px;
        }

        .target-row {
            display: flex;
            align-items: center;
            gap: 12px;
            min-width: 0;
        }

        .app-badge {
            width: 50px;
            height: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex: 0 0 auto;
            border-radius: 8px;
            overflow: hidden;
            background: var(--brand);
            color: #ffffff;
            font-size: 1.2rem;
            font-weight: 900;
            box-shadow: 0 10px 22px rgba(178, 64, 87, 0.2);
        }

        .app-badge img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .target-copy {
            display: grid;
            gap: 4px;
            min-width: 0;
        }

        .target-label {
            color: var(--ink-muted);
            font-size: 0.78rem;
            font-weight: 800;
        }

        h1 {
            margin: 0;
            color: var(--ink-strong);
            font-size: 1.86rem;
            line-height: 1.16;
        }

        .target-description {
            margin: 0;
            color: var(--ink-base);
            font-size: 0.94rem;
            line-height: 1.62;
        }

        .summary-card,
        .account-card,
        .permission-card,
        .risk-card,
        .technical-details {
            border: 1px solid var(--line-faint);
            border-radius: 8px;
            background: #ffffff;
        }

        .summary-card {
            display: grid;
            gap: 1px;
            overflow: hidden;
            background: var(--line-faint);
        }

        .summary-row {
            display: grid;
            grid-template-columns: 96px minmax(0, 1fr);
            gap: 12px;
            align-items: center;
            min-height: 40px;
            padding: 8px 12px;
            background: #ffffff;
        }

        .summary-label {
            color: var(--ink-muted);
            font-size: 0.76rem;
            font-weight: 800;
        }

        .summary-value {
            color: var(--ink-strong);
            font-size: 0.9rem;
            font-weight: 800;
            line-height: 1.38;
            word-break: break-word;
        }

        .account-card {
            display: flex;
            align-items: center;
            gap: 11px;
            padding: 12px;
            background: var(--paper-muted);
        }

        .account-avatar {
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex: 0 0 auto;
            border-radius: 8px;
            color: #ffffff;
            background: var(--blue);
            font-weight: 900;
        }

        .account-copy {
            display: grid;
            gap: 2px;
            min-width: 0;
        }

        .section-title {
            display: block;
            margin: 0;
            color: var(--ink-strong);
            font-size: 0.95rem;
            font-weight: 900;
            line-height: 1.35;
        }

        .account-name {
            margin: 0;
            color: var(--ink-strong);
            font-weight: 800;
            line-height: 1.35;
            word-break: break-word;
        }

        .section-copy {
            margin: 0;
            color: var(--ink-base);
            font-size: 0.84rem;
            line-height: 1.52;
        }

        .permission-card {
            padding: 14px;
        }

        .permission-head {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 10px;
        }

        .count-chip {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 26px;
            padding: 4px 9px;
            flex: 0 0 auto;
            border-radius: 999px;
            background: var(--brand-soft);
            color: var(--brand);
            border: 1px solid #e4c0ca;
            font-size: 0.76rem;
            font-weight: 900;
            white-space: nowrap;
        }

        .scope-list {
            list-style: none;
            padding: 0;
            margin: 0;
            display: grid;
            gap: 8px;
        }

        .scope-item {
            display: grid;
            grid-template-columns: 26px minmax(0, 1fr);
            gap: 10px;
            align-items: start;
            min-height: 48px;
            padding: 9px 0;
            border-top: 1px solid rgba(217, 203, 185, 0.54);
        }

        .scope-item:first-child {
            border-top: none;
            padding-top: 0;
        }

        .scope-mark {
            width: 26px;
            height: 26px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            background: #f8edf1;
            color: var(--brand);
            font-size: 0.9rem;
            font-weight: 900;
        }

        .scope-body {
            min-width: 0;
        }

        .scope-title {
            margin: 0 0 2px;
            color: var(--ink-strong);
            font-size: 0.92rem;
            line-height: 1.36;
        }

        .scope-description {
            margin: 0;
            color: var(--ink-base);
            line-height: 1.45;
            font-size: 0.82rem;
        }

        .scope-code {
            display: inline-flex;
            max-width: 100%;
            margin-top: 5px;
            color: var(--ink-muted);
            font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', monospace;
            font-size: 0.68rem;
            line-height: 1.35;
            word-break: break-all;
        }

        .risk-card {
            padding: 12px 14px;
            background: #fffaf5;
        }

        .risk-list {
            margin: 8px 0 0;
            padding-left: 18px;
            color: var(--ink-base);
            font-size: 0.83rem;
            line-height: 1.52;
        }

        .risk-list li + li {
            margin-top: 4px;
        }

        .technical-details {
            color: var(--ink-base);
            overflow: hidden;
        }

        .technical-details summary {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            min-height: 42px;
            padding: 10px 14px;
            cursor: pointer;
            color: var(--ink-strong);
            font-weight: 900;
            list-style: none;
        }

        .technical-details summary::-webkit-details-marker {
            display: none;
        }

        .technical-details summary::after {
            content: '+';
            display: inline-flex;
            width: 24px;
            height: 24px;
            align-items: center;
            justify-content: center;
            flex: 0 0 auto;
            border-radius: 999px;
            background: var(--paper-muted);
            color: var(--brand);
            border: 1px solid var(--line-soft);
        }

        .technical-details[open] summary::after {
            content: '-';
        }

        .technical-content {
            display: grid;
            gap: 9px;
            padding: 0 14px 14px;
        }

        .technical-hint {
            margin: 0;
            color: var(--ink-muted);
            font-size: 0.8rem;
            line-height: 1.5;
        }

        .technical-grid {
            display: grid;
            gap: 7px;
        }

        .technical-row {
            display: grid;
            gap: 4px;
            padding: 8px 10px;
            border-radius: 8px;
            background: var(--paper-muted);
            border: 1px solid rgba(217, 203, 185, 0.68);
        }

        .technical-label {
            color: var(--ink-muted);
            font-size: 0.72rem;
            font-weight: 800;
        }

        .technical-value {
            color: var(--ink-base);
            font-family: 'SFMono-Regular', Consolas, 'Liberation Mono', monospace;
            font-size: 0.73rem;
            line-height: 1.4;
            word-break: break-all;
        }

        .decision-form {
            display: grid;
            gap: 10px;
        }

        .decision-copy {
            margin: 0;
            color: var(--ink-base);
            font-size: 0.82rem;
            line-height: 1.5;
            text-align: center;
        }

        .button-group {
            display: grid;
            gap: 9px;
        }

        .action-button {
            min-height: 48px;
            width: 100%;
            padding: 11px 15px;
            border-radius: 999px;
            font-size: 14px;
            font-weight: 900;
            cursor: pointer;
            transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
        }

        .action-button.primary {
            border: none;
            background: var(--brand);
            color: #ffffff;
            box-shadow: 0 12px 24px rgba(178, 64, 87, 0.2);
        }

        .action-button.primary:hover {
            transform: translateY(-1px);
            background: var(--brand-deep);
            box-shadow: 0 16px 26px rgba(178, 64, 87, 0.25);
        }

        .action-button.secondary {
            border: 1px solid var(--line-soft);
            background: #ffffff;
            color: var(--ink-strong);
        }

        .action-button.secondary:hover {
            background: #f8f4ed;
        }

        @@media (min-width: 720px) {
            .button-group {
                grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
            }

            .action-button.secondary {
                order: 2;
            }
        }

        @@media (max-width: 640px) {
            body {
                align-items: flex-start;
                padding: 12px;
                background: var(--paper-base);
            }

            .card-body {
                gap: 14px;
                padding: 16px;
            }

            .topbar {
                align-items: flex-start;
                gap: 10px;
            }

            .brand-name {
                display: none;
            }

            .lang-button {
                min-height: 26px;
                padding: 4px 8px;
            }

            .target-row {
                align-items: flex-start;
            }

            .app-badge {
                width: 44px;
                height: 44px;
            }

            .target-description {
                font-size: 0.9rem;
            }

            h1 {
                font-size: 1.5rem;
            }

            .summary-row {
                grid-template-columns: 82px minmax(0, 1fr);
                gap: 8px;
                padding: 8px 10px;
            }

            .permission-card,
            .risk-card {
                padding: 12px;
            }

            .permission-head {
                align-items: center;
            }

            .decision-copy {
                text-align: left;
            }
        }
    </style>
</head>
<body>
    <main class="consent-shell" aria-label="@pageEyebrow">
        <section class="consent-card">
            <div class="card-accent" aria-hidden="true"></div>
            <div class="card-body">
                <header class="topbar">
                    <div class="brand-mark">
                        <div class="brand-icon">R</div>
                        <div class="brand-copy">
                            <p class="eyebrow">@pageEyebrow</p>
                            <p class="brand-name">Radish Auth</p>
                        </div>
                    </div>

                    <div class="lang-switcher" aria-label="Language">
                        <button type="button" class="lang-button @(CultureInfo.CurrentUICulture.Name.StartsWith("zh", StringComparison.OrdinalIgnoreCase) ? "active" : "")" onclick="switchLanguage('zh-CN')">中文</button>
                        <button type="button" class="lang-button @(CultureInfo.CurrentUICulture.Name.StartsWith("en", StringComparison.OrdinalIgnoreCase) ? "active" : "")" onclick="switchLanguage('en-US')">English</button>
                    </div>
                </header>

                <section class="hero" aria-label="@targetLabel">
                    <div class="target-row">
                        <div class="app-badge">
                            @if (!string.IsNullOrWhiteSpace(Model.ClientLogo))
                            {
                                <img src="@Model.ClientLogo" alt="@displayClientName" />
                            }
                            else
                            {
                                <span>@clientInitial</span>
                            }
                        </div>

                        <div class="target-copy">
                            <span class="target-label">@targetLabel</span>
                            <h1 class="display-serif">@Localizer["auth.consent.heading"]</h1>
                        </div>
                    </div>

                    <p class="target-description">@string.Format(Localizer["auth.consent.description"], displayClientName)</p>
                    @if (hasClientDescription)
                    {
                        <p class="target-description">@applicationDescription</p>
                    }
                </section>

                <section class="summary-card" aria-label="@appLabel">
                    <div class="summary-row">
                        <span class="summary-label">@appLabel</span>
                        <span class="summary-value">@displayClientName</span>
                    </div>
                    <div class="summary-row">
                        <span class="summary-label">@developerLabel</span>
                        <span class="summary-value">@developerName</span>
                    </div>
                    <div class="summary-row">
                        <span class="summary-label">@redirectLabel</span>
                        <span class="summary-value">@(string.IsNullOrWhiteSpace(redirectTarget) ? "-" : redirectTarget)</span>
                    </div>
                </section>

                <section class="account-card" aria-label="@accountTitle">
                    <div class="account-avatar">@accountInitial</div>
                    <div class="account-copy">
                        <strong class="section-title">@accountTitle</strong>
                        <p class="account-name">@loginIdentity</p>
                        <p class="section-copy">@accountHint</p>
                    </div>
                </section>

                <section class="permission-card" aria-label="@permissionTitle">
                    <div class="permission-head">
                        <div>
                            <strong class="section-title">@permissionTitle</strong>
                            <p class="section-copy">@permissionHint</p>
                        </div>
                        <span class="count-chip">@permissionCountLabel</span>
                    </div>

                    <ul class="scope-list">
                        @foreach (var scope in Model.Scopes)
                        {
                            var scopeInfo = DescribeScope(scope);

                            <li class="scope-item">
                                <span class="scope-mark" aria-hidden="true">✓</span>
                                <div class="scope-body">
                                    <h2 class="scope-title">@scopeInfo.Title</h2>
                                    <p class="scope-description">@scopeInfo.Description</p>
                                    <span class="scope-code">@scopeCodeLabel: @scope</span>
                                </div>
                            </li>
                        }
                    </ul>
                </section>

                <section class="risk-card" aria-label="@riskTitle">
                    <strong class="section-title">@riskTitle</strong>
                    <ul class="risk-list">
                        <li>@riskPoint1</li>
                        <li>@riskPoint2</li>
                    </ul>
                </section>

                <details class="technical-details">
                    <summary>@technicalTitle</summary>
                    <div class="technical-content">
                        <p class="technical-hint">@technicalHint</p>
                        <div class="technical-grid">
                            <div class="technical-row">
                                <span class="technical-label">@clientIdLabel</span>
                                <span class="technical-value">@Model.ClientId</span>
                            </div>
                            <div class="technical-row">
                                <span class="technical-label">@redirectUriLabel</span>
                                <span class="technical-value">@Model.RedirectUri</span>
                            </div>
                            <div class="technical-row">
                                <span class="technical-label">@rawScopeLabel</span>
                                <span class="technical-value">@Model.Scope</span>
                            </div>
                        </div>
                    </div>
                </details>

                <form class="decision-form" method="post">
                    <input type="hidden" name="client_id" value="@Model.ClientId" />
                    <input type="hidden" name="redirect_uri" value="@Model.RedirectUri" />
                    <input type="hidden" name="response_type" value="@Model.ResponseType" />
                    <input type="hidden" name="scope" value="@Model.Scope" />
                    <input type="hidden" name="state" value="@Model.State" />

                    <p class="decision-copy">@decisionHint</p>

                    <div class="button-group">
                        <button class="action-button primary" type="submit" name="decision" value="accept">@Localizer["auth.consent.allow"]</button>
                        <button class="action-button secondary" type="submit" name="decision" value="deny">@Localizer["auth.consent.deny"]</button>
                    </div>
                </form>
            </div>
        </section>
    </main>

    <script>
        function switchLanguage(culture) {
            const url = new URL(window.location.href);
            url.searchParams.set('culture', culture);
            url.searchParams.set('ui-culture', culture);
            window.location.href = url.toString();
        }
    </script>
</body>
</html>
