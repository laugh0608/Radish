@model Radish.Auth.ViewModels.Account.RegisterViewModel
@using System
@using System.Globalization
@inject Microsoft.Extensions.Localization.IStringLocalizer<Radish.Auth.Resources.Errors> Localizer

@{
    var client = Model.Client;
    ViewData["Title"] = Localizer["auth.register.title"];

    var heroTitle = Localizer["auth.register.heroTitle"];
    var heading = Localizer["auth.register.heading"];
    var description = Localizer["auth.register.description"];
    var rewardTitle = Localizer["auth.register.rewardTitle"];
    var rewardDescription = Localizer["auth.register.rewardDescription"];
    var fallbackServiceDescription = string.IsNullOrWhiteSpace(client.Description) ? Localizer["auth.register.defaultServiceDescription"].Value : client.Description;
    var fallbackClientName = string.IsNullOrWhiteSpace(client.DisplayName) ? Localizer["auth.register.defaultClientName"].Value : client.DisplayName;
    var serviceDescription = AuthClientText.Resolve(Localizer, client.ClientId, "description", fallbackServiceDescription);
    var clientName = AuthClientText.Resolve(Localizer, client.ClientId, "displayName", fallbackClientName);
    var developerName = AuthClientText.Resolve(Localizer, client.ClientId, "developerName", client.DeveloperName ?? string.Empty);
    var developerLabel = Localizer["auth.register.developerLabel"];
    var displayNameLabel = Localizer["auth.register.displayNameLabel"];
    var displayNamePlaceholder = Localizer["auth.register.displayNamePlaceholder", Model.DisplayNameMinLength, Model.DisplayNameMaxLength];
    var displayNameHint = Localizer["auth.register.displayNameHint"];
    var passwordLabel = Localizer["auth.register.passwordLabel"];
    var passwordPlaceholder = Localizer["auth.register.passwordPlaceholder"];
    var confirmPasswordLabel = Localizer["auth.register.confirmPasswordLabel"];
    var confirmPasswordPlaceholder = Localizer["auth.register.confirmPasswordPlaceholder"];
    var emailLabel = Localizer["auth.register.emailLabel"];
    var emailPlaceholder = Localizer["auth.register.emailPlaceholder"];
    var submitText = Localizer["auth.register.submit"];
    var loginPrompt = Localizer["auth.register.loginPrompt"];
    var loginAction = Localizer["auth.register.loginAction"];
    var showPasswordText = Localizer["auth.register.password.show"];
    var hidePasswordText = Localizer["auth.register.password.hide"];
    var logoAlt = Localizer["auth.register.client.logoAlt"];
}

<!DOCTYPE html>
<html lang="@(CultureInfo.CurrentUICulture.Name)">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
        :root {
            color-scheme: light;
            --paper-base: #fbfaf6;
            --paper-panel: rgba(255, 253, 249, 0.95);
            --paper-soft: #f4f6ef;
            --line-soft: rgba(148, 163, 184, 0.22);
            --line-strong: rgba(148, 163, 184, 0.34);
            --ink-strong: #172033;
            --ink-base: #475569;
            --accent-primary: #2c7a63;
            --accent-secondary: #4f9a76;
            --accent-soft: rgba(232, 245, 236, 0.86);
            --success-bg: #e6f6ee;
            --success-border: #9fd4b8;
            --error-bg: #fdeeed;
            --error-border: #efc4be;
            --reward-bg: linear-gradient(135deg, #fbf1cc 0%, #fff8e5 100%);
            --reward-border: #edd89a;
        }

        * {
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
            margin: 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: clamp(16px, 3vw, 32px);
            background:
                radial-gradient(circle at top, rgba(91, 163, 130, 0.16), transparent 32%),
                linear-gradient(180deg, #f7faf6 0%, #f8fafc 46%, #fcfcfb 100%);
            color: var(--ink-strong);
        }

        .display-serif {
            font-family: Georgia, 'Times New Roman', 'Songti SC', 'STSong', serif;
            letter-spacing: 0.02em;
        }

        .auth-shell {
            width: 100%;
            max-width: 1080px;
            background: var(--paper-panel);
            border-radius: 24px;
            border: 1px solid rgba(226, 232, 240, 0.72);
            box-shadow: 0 26px 60px rgba(15, 23, 42, 0.12);
            overflow: hidden;
            backdrop-filter: blur(10px);
        }

        .auth-layout {
            display: grid;
            grid-template-columns: minmax(280px, 0.9fr) minmax(460px, 1.1fr);
        }

        .client-panel {
            position: relative;
            padding: 36px 32px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            gap: 24px;
            color: #f7fffb;
            background:
                linear-gradient(160deg, #60a88a 0%, #3b8b73 54%, #2d6c5a 100%);
        }

        .client-panel::before {
            content: '';
            position: absolute;
            inset: 0;
            background:
                radial-gradient(circle at 16% 18%, rgba(255,255,255,0.2), transparent 28%),
                linear-gradient(180deg, rgba(255,255,255,0.08), transparent 40%);
            pointer-events: none;
        }

        .client-header,
        .client-meta-list {
            position: relative;
            z-index: 1;
        }

        .client-logo {
            width: 60px;
            height: 60px;
            border-radius: 18px;
            background: rgba(255,255,255,0.18);
            border: 1px solid rgba(255,255,255,0.22);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 18px;
            overflow: hidden;
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.18);
        }

        .client-logo img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .client-logo-placeholder {
            font-size: 1.5rem;
            font-weight: 700;
            color: rgba(255,255,255,0.94);
        }

        .client-title {
            display: inline-flex;
            align-items: center;
            width: fit-content;
            padding: 6px 12px;
            border-radius: 999px;
            margin: 0 0 14px;
            background: rgba(255,255,255,0.12);
            border: 1px solid rgba(255,255,255,0.18);
            color: rgba(255,255,255,0.88);
            font-size: 0.76rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .client-name {
            margin: 0 0 10px;
            font-size: 1.82rem;
            line-height: 1.18;
            color: #ffffff;
        }

        .client-summary {
            margin: 0;
            color: rgba(255,255,255,0.86);
            font-size: 0.96rem;
            line-height: 1.8;
        }

        .client-meta-list {
            display: grid;
            gap: 10px;
        }

        .client-meta-item {
            padding: 12px 14px;
            border-radius: 14px;
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.14);
        }

        .client-meta-label {
            display: block;
            color: rgba(255,255,255,0.72);
            font-size: 0.72rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .client-meta-value {
            margin-top: 4px;
            color: #ffffff;
            font-size: 0.95rem;
            line-height: 1.55;
            word-break: break-word;
        }

        .form-panel {
            padding: 34px 36px;
            display: flex;
            flex-direction: column;
            background: linear-gradient(180deg, #fffefe 0%, #fffdf9 100%);
        }

        .panel-head {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 18px;
            margin-bottom: 18px;
        }

        .heading-group h1 {
            margin: 0 0 8px;
            font-size: 1.86rem;
            line-height: 1.12;
            color: var(--ink-strong);
        }

        .description {
            margin: 0;
            color: var(--ink-base);
            line-height: 1.72;
            max-width: 40ch;
        }

        .lang-switcher {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px;
            border-radius: 999px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            flex-shrink: 0;
        }

        .lang-button {
            padding: 7px 12px;
            background: transparent;
            color: #475569;
            border: none;
            border-radius: 999px;
            cursor: pointer;
            font-size: 12px;
            transition: all 0.2s ease;
        }

        .lang-button:hover,
        .lang-button.active {
            background: #172033;
            color: #fff;
        }

        .notice {
            padding: 12px 14px;
            border-radius: 14px;
            margin-bottom: 12px;
            font-size: 0.92rem;
            line-height: 1.6;
        }

        .success {
            color: #0f5132;
            background: var(--success-bg);
            border: 1px solid var(--success-border);
        }

        .error {
            color: #94251a;
            background: var(--error-bg);
            border: 1px solid var(--error-border);
        }

        .reward-banner {
            margin-bottom: 14px;
            padding: 12px 14px;
            border-radius: 16px;
            background: var(--reward-bg);
            border: 1px solid var(--reward-border);
            display: flex;
            align-items: flex-start;
            gap: 12px;
        }

        .reward-icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            border-radius: 12px;
            background: rgba(255,255,255,0.5);
            font-size: 1.1rem;
            flex-shrink: 0;
        }

        .reward-copy strong {
            display: block;
            color: #8b5e16;
            font-size: 0.92rem;
            margin-bottom: 4px;
        }

        .reward-copy p {
            margin: 0;
            color: #7c5815;
            font-size: 0.84rem;
            line-height: 1.55;
        }

        form {
            display: grid;
            gap: 12px;
        }

        .form-row {
            display: grid;
            gap: 12px;
        }

        .form-row.double {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .form-group {
            display: grid;
            gap: 6px;
        }

        label {
            color: var(--ink-strong);
            font-weight: 600;
            font-size: 0.92rem;
        }

        label .optional {
            margin-left: 4px;
            color: #64748b;
            font-size: 0.82rem;
            font-weight: 400;
        }

        .field-hint {
            color: #64748b;
            font-size: 0.82rem;
            line-height: 1.5;
        }

        input[type="text"],
        input[type="email"],
        input[type="password"] {
            width: 100%;
            min-height: 46px;
            padding: 11px 13px;
            border: 1px solid #d8dee8;
            border-radius: 12px;
            font-size: 15px;
            color: var(--ink-strong);
            background: #ffffff;
            transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
        }

        input[type="text"]:focus,
        input[type="email"]:focus,
        input[type="password"]:focus {
            outline: none;
            border-color: rgba(44, 122, 99, 0.82);
            box-shadow: 0 0 0 3px rgba(44, 122, 99, 0.16);
            background: #fffefe;
        }

        input[type="password"]::-ms-reveal,
        input[type="password"]::-ms-clear {
            display: none;
        }

        input[type="password"]::-webkit-credentials-auto-fill-button,
        input[type="password"]::-webkit-contacts-auto-fill-button {
            visibility: hidden;
            pointer-events: none;
            position: absolute;
        }

        .password-field {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            gap: 8px;
            align-items: center;
        }

        .toggle-password {
            min-height: 46px;
            padding: 0 16px;
            border-radius: 12px;
            border: 1px solid #d8dee8;
            background: #fbfcfd;
            cursor: pointer;
            font-size: 13px;
            color: #475569;
            transition: all 0.2s ease;
            white-space: nowrap;
        }

        .toggle-password:hover {
            background: var(--accent-soft);
            border-color: rgba(44, 122, 99, 0.36);
            color: var(--accent-primary);
        }

        .toggle-password:focus {
            outline: none;
            box-shadow: 0 0 0 3px rgba(44, 122, 99, 0.16);
        }

        .button-group {
            margin-top: 4px;
        }

        button[type="submit"] {
            width: 100%;
            min-height: 48px;
            padding: 12px 16px;
            border: none;
            border-radius: 14px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
            color: #fff;
            box-shadow: 0 14px 28px rgba(44, 122, 99, 0.2);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        button[type="submit"]:hover {
            transform: translateY(-1px);
            box-shadow: 0 18px 30px rgba(44, 122, 99, 0.24);
        }

        .login-link {
            margin-top: 14px;
            text-align: center;
            color: #64748b;
            font-size: 0.9rem;
        }

        .login-link a {
            color: var(--accent-primary);
            text-decoration: none;
            font-weight: 600;
        }

        .login-link a:hover {
            text-decoration: underline;
        }

        @@media (max-width: 920px) {
            .auth-layout {
                grid-template-columns: 1fr;
            }

            .client-panel,
            .form-panel {
                padding: 28px 24px;
            }

            .panel-head {
                flex-direction: column-reverse;
                align-items: stretch;
            }

            .lang-switcher {
                align-self: flex-start;
            }
        }

        @@media (max-width: 720px) {
            .form-row.double {
                grid-template-columns: 1fr;
            }

            .password-field {
                grid-template-columns: 1fr;
            }

            .toggle-password {
                width: 100%;
            }
        }

        @@media (max-width: 640px) {
            body {
                align-items: flex-start;
            }

            .client-name,
            .heading-group h1 {
                font-size: 1.58rem;
            }
        }
    </style>
</head>
<body>
    <div class="auth-shell">
        <div class="auth-layout">
            <section class="client-panel">
                <div class="client-header">
                    <div class="client-logo">
                        @if (!string.IsNullOrWhiteSpace(client.Logo))
                        {
                            <img src="@client.Logo" alt="@logoAlt" />
                        }
                        else
                        {
                            <div class="client-logo-placeholder">@(string.IsNullOrEmpty(clientName) ? "R" : clientName[0])</div>
                        }
                    </div>

                    <p class="client-title">@heroTitle</p>
                    <h2 class="client-name display-serif">@clientName</h2>
                    <p class="client-summary">@serviceDescription</p>
                </div>

                <div class="client-meta-list">
                    <div class="client-meta-item">
                        <span class="client-meta-label">Client ID</span>
                        <div class="client-meta-value">@(string.IsNullOrWhiteSpace(client.ClientId) ? "-" : client.ClientId)</div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(developerName))
                    {
                        <div class="client-meta-item">
                            <span class="client-meta-label">@developerLabel</span>
                            <div class="client-meta-value">@developerName</div>
                        </div>
                    }
                </div>
            </section>

            <section class="form-panel">
                <div class="panel-head">
                    <div class="heading-group">
                        <h1 class="display-serif">@heading</h1>
                        <p class="description">@description</p>
                    </div>

                    <div class="lang-switcher">
                        <button type="button" class="lang-button @(CultureInfo.CurrentUICulture.Name.StartsWith("zh", StringComparison.OrdinalIgnoreCase) ? "active" : "")" onclick="switchLanguage('zh')">中文</button>
                        <button type="button" class="lang-button @(CultureInfo.CurrentUICulture.Name.StartsWith("en", StringComparison.OrdinalIgnoreCase) ? "active" : "")" onclick="switchLanguage('en')">English</button>
                    </div>
                </div>

                <div class="reward-banner">
                    <div class="reward-icon">🎁</div>
                    <div class="reward-copy">
                        <strong>@rewardTitle</strong>
                        <p>@rewardDescription</p>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                {
                    <div class="notice success">@Model.SuccessMessage</div>
                }

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="notice error">@Model.ErrorMessage</div>
                }

                <form asp-controller="Account" asp-action="Register" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />

                    <div class="form-group">
                        <label>@displayNameLabel</label>
                        <input type="text" name="displayName" asp-for="DisplayName" placeholder="@displayNamePlaceholder" autocomplete="nickname" required />
                        <span class="field-hint">@displayNameHint</span>
                    </div>

                    <div class="form-row double">
                        <div class="form-group">
                            <label>@passwordLabel</label>
                            <div class="password-field">
                                <input id="passwordInput" type="password" name="password" asp-for="Password" placeholder="@passwordPlaceholder" autocomplete="new-password" required />
                                <button type="button"
                                        id="togglePassword"
                                        class="toggle-password"
                                        data-show="@showPasswordText"
                                        data-hide="@hidePasswordText"
                                        aria-pressed="false">
                                    @showPasswordText
                                </button>
                            </div>
                        </div>

                        <div class="form-group">
                            <label>@confirmPasswordLabel</label>
                            <div class="password-field">
                                <input id="confirmPasswordInput" type="password" name="confirmPassword" asp-for="ConfirmPassword" placeholder="@confirmPasswordPlaceholder" autocomplete="new-password" required />
                                <button type="button"
                                        id="toggleConfirmPassword"
                                        class="toggle-password"
                                        data-show="@showPasswordText"
                                        data-hide="@hidePasswordText"
                                        aria-pressed="false">
                                    @showPasswordText
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>@emailLabel</label>
                        <input type="email" name="email" asp-for="Email" placeholder="@emailPlaceholder" autocomplete="email" required />
                    </div>

                    <div class="button-group">
                        <button type="submit">@submitText</button>
                    </div>

                    <div class="login-link">
                        @loginPrompt <a href="@Url.Action("Login", "Account", new { returnUrl = Model.ReturnUrl, culture = CultureInfo.CurrentUICulture.Name })">@loginAction</a>
                    </div>
                </form>
            </section>
        </div>
    </div>

    <script>
        function switchLanguage(culture) {
            const returnUrl = new URL(window.location.href);
            returnUrl.searchParams.delete('culture');
            returnUrl.searchParams.delete('ui-culture');
            const localReturnUrl = `${returnUrl.pathname}${returnUrl.search}${returnUrl.hash}`;
            const switchUrl = new URL('@Url.Action("SetLanguage", "Account")', window.location.origin);
            switchUrl.searchParams.set('culture', culture);
            switchUrl.searchParams.set('returnUrl', localReturnUrl);
            window.location.assign(switchUrl.toString());
        }

        document.addEventListener('DOMContentLoaded', () => {
            function setupPasswordToggle(inputId, buttonId) {
                const passwordInput = document.getElementById(inputId);
                const toggleButton = document.getElementById(buttonId);
                if (!passwordInput || !toggleButton) {
                    return;
                }

                toggleButton.addEventListener('click', () => {
                    const shouldShow = passwordInput.type === 'password';
                    passwordInput.type = shouldShow ? 'text' : 'password';
                    toggleButton.textContent = shouldShow ? toggleButton.dataset.hide : toggleButton.dataset.show;
                    toggleButton.setAttribute('aria-pressed', shouldShow ? 'true' : 'false');
                });
            }

            setupPasswordToggle('passwordInput', 'togglePassword');
            setupPasswordToggle('confirmPasswordInput', 'toggleConfirmPassword');
        });
    </script>
</body>
</html>
