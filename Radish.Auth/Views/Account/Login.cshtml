@model Radish.Auth.ViewModels.Account.LoginViewModel
@using System
@using System.Globalization
@using Microsoft.Extensions.Configuration
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<Radish.Auth.Resources.Errors> Localizer
@inject IConfiguration Configuration

@{
    ViewData["Title"] = Localizer["auth.login.title"];
    var client = Model.Client;
    var isZh = CultureInfo.CurrentUICulture.Name.StartsWith("zh", StringComparison.OrdinalIgnoreCase);
    var clientName = string.IsNullOrWhiteSpace(client.DisplayName) ? Localizer["auth.login.client.unknown"].Value : client.DisplayName;
    var clientDescription = string.IsNullOrWhiteSpace(client.Description) ? Localizer["auth.login.client.defaultDescription"].Value : client.Description;
    var developerLabel = isZh ? "开发者" : "Developer";
    var registerPrompt = isZh ? "没有账号？" : "Need an account?";
    var registerAction = isZh ? "立即注册" : "Create one";
    var testAccountHint = isZh ? "可直接用于本地联调和授权链路验证。" : "Use this demo account for local sign-in and consent testing.";
    var loginSubmittingText = isZh ? "登录中..." : "Signing in...";
    var showTestAccount = Configuration.GetValue<bool?>("AuthUi:ShowTestAccountHint") ?? true;
}

<!DOCTYPE html>
<html lang="@(CultureInfo.CurrentUICulture.Name)">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
        :root {
            color-scheme: light;
            --paper-base: #fcfaf7;
            --paper-panel: rgba(255, 252, 248, 0.94);
            --paper-soft: #f8f3ee;
            --line-soft: rgba(148, 163, 184, 0.22);
            --line-strong: rgba(148, 163, 184, 0.34);
            --ink-strong: #172033;
            --ink-base: #475569;
            --accent-primary: #8f4f56;
            --accent-secondary: #b26a67;
            --accent-soft: rgba(255, 244, 240, 0.74);
            --success-bg: #e6f6ee;
            --success-border: #9fd4b8;
            --error-bg: #fdeeed;
            --error-border: #efc4be;
        }

        * {
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
            margin: 0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: clamp(16px, 3vw, 32px);
            background:
                radial-gradient(circle at top, rgba(191, 122, 122, 0.16), transparent 32%),
                linear-gradient(180deg, #fbf7f2 0%, #f8fafc 46%, #fcfcfb 100%);
            color: var(--ink-strong);
        }

        .display-serif {
            font-family: Georgia, 'Times New Roman', 'Songti SC', 'STSong', serif;
            letter-spacing: 0.02em;
        }

        .auth-shell {
            width: 100%;
            max-width: 1040px;
            background: var(--paper-panel);
            border-radius: 24px;
            border: 1px solid rgba(226, 232, 240, 0.72);
            box-shadow: 0 26px 60px rgba(15, 23, 42, 0.12);
            overflow: hidden;
            backdrop-filter: blur(10px);
        }

        .auth-layout {
            display: grid;
            grid-template-columns: minmax(280px, 0.9fr) minmax(420px, 1.1fr);
        }

        .client-panel {
            position: relative;
            padding: 36px 32px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            gap: 24px;
            color: #fffaf7;
            background:
                linear-gradient(160deg, #d5938e 0%, #bf756e 52%, #965353 100%);
        }

        .client-panel::before {
            content: '';
            position: absolute;
            inset: 0;
            background:
                radial-gradient(circle at 18% 16%, rgba(255,255,255,0.24), transparent 26%),
                linear-gradient(180deg, rgba(255,255,255,0.08), transparent 40%);
            pointer-events: none;
        }

        .client-header,
        .client-meta-list {
            position: relative;
            z-index: 1;
        }

        .client-logo {
            width: 60px;
            height: 60px;
            border-radius: 18px;
            background: rgba(255,255,255,0.18);
            border: 1px solid rgba(255,255,255,0.22);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 18px;
            overflow: hidden;
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.18);
        }

        .client-logo img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .client-logo-placeholder {
            font-size: 1.5rem;
            font-weight: 700;
            color: rgba(255,255,255,0.94);
        }

        .client-title {
            display: inline-flex;
            align-items: center;
            width: fit-content;
            padding: 6px 12px;
            border-radius: 999px;
            margin: 0 0 14px;
            background: rgba(255,255,255,0.12);
            border: 1px solid rgba(255,255,255,0.18);
            color: rgba(255,255,255,0.88);
            font-size: 0.76rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .client-name {
            margin: 0 0 10px;
            font-size: 1.82rem;
            line-height: 1.18;
            color: #ffffff;
        }

        .client-summary {
            margin: 0;
            color: rgba(255,255,255,0.86);
            font-size: 0.96rem;
            line-height: 1.8;
        }

        .client-meta-list {
            display: grid;
            gap: 10px;
        }

        .client-meta-item {
            padding: 12px 14px;
            border-radius: 14px;
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.14);
        }

        .client-meta-label {
            display: block;
            color: rgba(255,255,255,0.72);
            font-size: 0.72rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .client-meta-value {
            margin-top: 4px;
            color: #ffffff;
            font-size: 0.95rem;
            line-height: 1.55;
            word-break: break-word;
        }

        .form-panel {
            padding: 34px 36px;
            display: flex;
            flex-direction: column;
            background: linear-gradient(180deg, #fffefe 0%, #fffdf9 100%);
        }

        .panel-head {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 18px;
            margin-bottom: 18px;
        }

        .heading-group h1 {
            margin: 0 0 8px;
            font-size: 1.86rem;
            line-height: 1.12;
            color: var(--ink-strong);
        }

        .description {
            margin: 0;
            color: var(--ink-base);
            line-height: 1.72;
            max-width: 36ch;
        }

        .lang-switcher {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px;
            border-radius: 999px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            flex-shrink: 0;
        }

        .lang-button {
            padding: 7px 12px;
            background: transparent;
            color: #475569;
            border: none;
            border-radius: 999px;
            cursor: pointer;
            font-size: 12px;
            transition: all 0.2s ease;
        }

        .lang-button:hover,
        .lang-button.active {
            background: #172033;
            color: #fff;
        }

        .notice {
            padding: 12px 14px;
            border-radius: 14px;
            margin-bottom: 12px;
            font-size: 0.92rem;
            line-height: 1.6;
        }

        .success {
            color: #0f5132;
            background: var(--success-bg);
            border: 1px solid var(--success-border);
        }

        .error {
            color: #94251a;
            background: var(--error-bg);
            border: 1px solid var(--error-border);
        }

        .test-account {
            margin-bottom: 14px;
            padding: 14px;
            border-radius: 16px;
            background: linear-gradient(180deg, #fff9f4 0%, #fffdf9 100%);
            border: 1px solid #eee4d8;
        }

        .test-account-head {
            display: flex;
            align-items: baseline;
            justify-content: space-between;
            gap: 12px;
            margin-bottom: 10px;
        }

        .test-account-head strong {
            color: var(--ink-strong);
            font-size: 0.94rem;
        }

        .test-account-head small {
            color: #64748b;
            font-size: 0.76rem;
        }

        .test-account-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 10px;
        }

        .test-account-item {
            padding: 10px 12px;
            border-radius: 12px;
            background: rgba(255,255,255,0.88);
            border: 1px solid #f1e7dd;
        }

        .test-account-item span {
            display: block;
            margin-bottom: 6px;
            color: #64748b;
            font-size: 0.78rem;
        }

        .test-account-item code {
            display: inline-flex;
            align-items: center;
            padding: 4px 8px;
            border-radius: 999px;
            background: var(--paper-soft);
            color: var(--accent-primary);
            font-size: 0.84rem;
            border: 1px solid #ecdcd3;
        }

        form {
            display: grid;
            gap: 12px;
        }

        .form-group {
            display: grid;
            gap: 6px;
        }

        label {
            color: var(--ink-strong);
            font-weight: 600;
            font-size: 0.92rem;
        }

        input[type="text"],
        input[type="password"] {
            width: 100%;
            min-height: 46px;
            padding: 11px 13px;
            border: 1px solid #d8dee8;
            border-radius: 12px;
            font-size: 15px;
            color: var(--ink-strong);
            background: #ffffff;
            transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
        }

        input[type="text"]:focus,
        input[type="password"]:focus {
            outline: none;
            border-color: rgba(143, 79, 86, 0.8);
            box-shadow: 0 0 0 3px rgba(143, 79, 86, 0.16);
            background: #fffdfc;
        }

        input[type="password"]::-ms-reveal,
        input[type="password"]::-ms-clear {
            display: none;
        }

        input[type="password"]::-webkit-credentials-auto-fill-button,
        input[type="password"]::-webkit-contacts-auto-fill-button {
            visibility: hidden;
            pointer-events: none;
            position: absolute;
        }

        .password-field {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            gap: 8px;
            align-items: center;
        }

        .toggle-password {
            min-height: 46px;
            padding: 0 16px;
            border-radius: 12px;
            border: 1px solid #d8dee8;
            background: #fbfcfd;
            cursor: pointer;
            font-size: 13px;
            color: #475569;
            transition: all 0.2s ease;
            white-space: nowrap;
        }

        .toggle-password:hover {
            background: var(--accent-soft);
            border-color: rgba(143, 79, 86, 0.34);
            color: var(--accent-primary);
        }

        .toggle-password:focus {
            outline: none;
            box-shadow: 0 0 0 3px rgba(143, 79, 86, 0.16);
        }

        .button-group {
            margin-top: 4px;
        }

        button[type="submit"] {
            width: 100%;
            min-height: 48px;
            padding: 12px 16px;
            border: none;
            border-radius: 14px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
            color: #fff;
            box-shadow: 0 14px 28px rgba(143, 79, 86, 0.2);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        button[type="submit"]:hover {
            transform: translateY(-1px);
            box-shadow: 0 18px 30px rgba(143, 79, 86, 0.24);
        }

        .register-link {
            margin-top: 14px;
            text-align: center;
            color: #64748b;
            font-size: 0.9rem;
        }

        .register-link a {
            color: var(--accent-primary);
            text-decoration: none;
            font-weight: 600;
        }

        .register-link a:hover {
            text-decoration: underline;
        }

        @@media (max-width: 920px) {
            .auth-layout {
                grid-template-columns: 1fr;
            }

            .client-panel,
            .form-panel {
                padding: 28px 24px;
            }

            .panel-head {
                flex-direction: column-reverse;
                align-items: stretch;
            }

            .lang-switcher {
                align-self: flex-start;
            }
        }

        @@media (max-width: 640px) {
            body {
                align-items: flex-start;
            }

            .test-account-grid {
                grid-template-columns: 1fr;
            }

            .password-field {
                grid-template-columns: 1fr;
            }

            .toggle-password {
                width: 100%;
            }

            .client-name,
            .heading-group h1 {
                font-size: 1.58rem;
            }
        }
    </style>
</head>
<body>
    <div class="auth-shell">
        <div class="auth-layout">
            <section class="client-panel">
                <div class="client-header">
                    <div class="client-logo">
                        @if (!string.IsNullOrWhiteSpace(client.Logo))
                        {
                            <img src="@client.Logo" alt="@Localizer["auth.login.client.logoAlt"]" />
                        }
                        else
                        {
                            <div class="client-logo-placeholder">@(string.IsNullOrEmpty(clientName) ? "R" : clientName[0])</div>
                        }
                    </div>

                    <p class="client-title">@Localizer["auth.login.client.title"]</p>
                    <h2 class="client-name display-serif">@clientName</h2>
                    <p class="client-summary">@clientDescription</p>
                </div>

                <div class="client-meta-list">
                    <div class="client-meta-item">
                        <span class="client-meta-label">@Localizer["auth.login.client.id"]</span>
                        <div class="client-meta-value">@(string.IsNullOrWhiteSpace(client.ClientId) ? "-" : client.ClientId)</div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(client.DeveloperName))
                    {
                        <div class="client-meta-item">
                            <span class="client-meta-label">@developerLabel</span>
                            <div class="client-meta-value">@client.DeveloperName</div>
                        </div>
                    }
                </div>
            </section>

            <section class="form-panel">
                <div class="panel-head">
                    <div class="heading-group">
                        <h1 class="display-serif">@Localizer["auth.login.heading"]</h1>
                        <p class="description">@Localizer["auth.login.description"]</p>
                    </div>

                    <div class="lang-switcher">
                        <button type="button" class="lang-button @(CultureInfo.CurrentUICulture.Name.StartsWith("zh", StringComparison.OrdinalIgnoreCase) ? "active" : "")" onclick="switchLanguage('zh-CN')">中文</button>
                        <button type="button" class="lang-button @(CultureInfo.CurrentUICulture.Name.StartsWith("en", StringComparison.OrdinalIgnoreCase) ? "active" : "")" onclick="switchLanguage('en-US')">English</button>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                {
                    <div class="notice success">@Model.SuccessMessage</div>
                }

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="notice error">@Model.ErrorMessage</div>
                }

                @if (showTestAccount)
                {
                    <div class="test-account">
                        <div class="test-account-head">
                            <strong>@Localizer["auth.login.testAccount"]</strong>
                            <small>@testAccountHint</small>
                        </div>

                        <div class="test-account-grid">
                            <div class="test-account-item">
                                <span>@Localizer["auth.login.testAccount.username"]</span>
                                <code>test</code>
                            </div>
                            <div class="test-account-item">
                                <span>@Localizer["auth.login.testAccount.password"]</span>
                                <code>test123456</code>
                            </div>
                        </div>
                    </div>
                }

                <form id="loginForm" asp-controller="Account" asp-action="Login" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />

                    <div class="form-group">
                        <label>@Localizer["auth.login.usernameLabel"]</label>
                        <input type="text" name="username" value="@(string.IsNullOrWhiteSpace(Model.PrefillUserName) ? string.Empty : Model.PrefillUserName)" autocomplete="username" />
                    </div>

                    <div class="form-group">
                        <label>@Localizer["auth.login.passwordLabel"]</label>
                        <div class="password-field">
                            <input id="passwordInput" type="password" name="password" value="" autocomplete="current-password" />
                            <button type="button"
                                    id="togglePassword"
                                    class="toggle-password"
                                    data-show="@Localizer["auth.login.password.show"]"
                                    data-hide="@Localizer["auth.login.password.hide"]"
                                    aria-pressed="false">
                                @Localizer["auth.login.password.show"]
                            </button>
                        </div>
                    </div>

                    <div class="button-group">
                        <button id="loginSubmitButton" type="submit" data-submitting="@loginSubmittingText">
                            @Localizer["auth.login.submit"]
                        </button>
                    </div>

                    <div class="register-link">
                        @registerPrompt <a href="@Url.Action("Register", "Account", new { returnUrl = Model.ReturnUrl })">@registerAction</a>
                    </div>
                </form>
            </section>
        </div>
    </div>

    <script>
        function switchLanguage(culture) {
            const url = new URL(window.location.href);
            url.searchParams.set('culture', culture);
            url.searchParams.set('ui-culture', culture);
            window.location.href = url.toString();
        }

        document.addEventListener('DOMContentLoaded', () => {
            const passwordInput = document.getElementById('passwordInput');
            const toggleButton = document.getElementById('togglePassword');
            const loginForm = document.getElementById('loginForm');
            const submitButton = document.getElementById('loginSubmitButton');

            if (passwordInput && toggleButton) {
                toggleButton.addEventListener('click', () => {
                    const shouldShow = passwordInput.type === 'password';
                    passwordInput.type = shouldShow ? 'text' : 'password';
                    toggleButton.textContent = shouldShow ? toggleButton.dataset.hide : toggleButton.dataset.show;
                    toggleButton.setAttribute('aria-pressed', shouldShow ? 'true' : 'false');
                });
            }

            if (loginForm && submitButton) {
                let isSubmitting = false;

                loginForm.addEventListener('submit', (event) => {
                    if (isSubmitting) {
                        event.preventDefault();
                        return;
                    }

                    isSubmitting = true;
                    submitButton.disabled = true;
                    submitButton.setAttribute('aria-disabled', 'true');
                    submitButton.textContent = submitButton.dataset.submitting || submitButton.textContent;
                });
            }
        });
    </script>
</body>
</html>
