#!/bin/sh

repo_root="$(git rev-parse --show-toplevel)"

if [ -z "$repo_root" ]; then
  echo "[pre-commit] 无法定位仓库根目录。"
  exit 1
fi

cd "$repo_root" || exit 1
git diff --cached --name-only --diff-filter=ACMR -z | node Scripts/check-repo-hygiene.mjs --stdin-z
status=$?

if [ $status -ne 0 ]; then
  exit $status
fi

git diff --cached --name-only --diff-filter=ACMR -z | node Scripts/lint-frontend-changed.mjs --stdin-z
