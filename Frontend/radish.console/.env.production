# 生产环境配置

# API 基础 URL (生产环境应该通过 Gateway 访问)
VITE_API_BASE_URL=https://your-domain.com

# Auth Server URL
VITE_AUTH_SERVER_URL=https://your-domain.com

# 是否启用调试模式
VITE_DEBUG=false

# 是否启用 Token 自动刷新调试定时器（生产环境保持关闭）
VITE_TOKEN_AUTO_REFRESH_DEBUG=false

# 功能开关
VITE_FEATURE_THEME_SWITCH=true
VITE_FEATURE_GLOBAL_SEARCH=true
