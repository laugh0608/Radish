# 开发环境配置

# API 基础 URL（统一走 Gateway）
VITE_API_BASE_URL=https://localhost:5000

# Auth Server URL（统一走 Gateway）
VITE_AUTH_SERVER_URL=https://localhost:5000

# 是否启用调试模式
VITE_DEBUG=true

# 是否启用 Token 自动刷新调试定时器（仅调试建议开启）
VITE_TOKEN_AUTO_REFRESH_DEBUG=true

# 功能开关
VITE_FEATURE_THEME_SWITCH=true
VITE_FEATURE_GLOBAL_SEARCH=false
