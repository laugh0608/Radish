# Copy this file to Deploy/.env and replace the example values before rollout.

# Compose project name controls container and volume prefixes.
# Use a different value only when test and release must coexist on the same host.
COMPOSE_PROJECT_NAME=radish

# Images to pull for deployment.
# Use a fixed v*-test tag for test deployment, or a fixed v*-release tag for release deployment.
RADISH_IMAGE_REGISTRY=ghcr.io/laugh0608
RADISH_IMAGE_TAG=v26.3.2-release

# Public HTTPS URL exposed by the reverse proxy and used as the frontend runtime fallback origin.
RADISH_PUBLIC_URL=https://radish.example.com
RADISH_GATEWAY_HTTP_PORT=5000

# PostgreSQL / Redis runtime dependencies.
RADISH_POSTGRES_USER=radish
RADISH_POSTGRES_PASSWORD=ChangeMePostgres123!
RADISH_POSTGRES_MAIN_DB=radish
RADISH_POSTGRES_LOG_DB=radish_log
RADISH_POSTGRES_MESSAGE_DB=radish_message
RADISH_POSTGRES_CHAT_DB=radish_chat
RADISH_POSTGRES_OPENIDDICT_DB=radish_openiddict
RADISH_POSTGRES_HANGFIRE_DB=radish_hangfire
RADISH_REDIS_PASSWORD=ChangeMeRedis123!

# Deployment seed safety.
# Keep this false for test/prod so DbMigrate never creates default admin/test accounts or fixed passwords.
RADISH_SEED_DEVELOPER_DEFAULTS_ENABLED=false

# Auth OIDC signing / encryption certificates.
# The auth container generates missing certificates into the radish-auth-certs volume on first start.
# The signing certificate is also mounted read-only into the api container for local JWT validation.
# Generate the two certificate passwords before first rollout, for example:
#   openssl rand -hex 32
RADISH_AUTH_CERT_AUTO_GENERATE=true
RADISH_AUTH_CERT_VALID_DAYS=7300
RADISH_AUTH_SIGNING_CERT_PASSWORD=replace_with_openssl_rand_hex_32
RADISH_AUTH_ENCRYPTION_CERT_PASSWORD=replace_with_another_openssl_rand_hex_32
