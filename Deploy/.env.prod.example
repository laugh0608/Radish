# Copy this file to Deploy/.env.prod and replace the example values before rollout.

# Images to pull for production deployment.
# Replace `your-org` and `v26.3.1-release` with the actual GHCR owner and immutable release tag.
# Production should prefer a fixed release tag over `latest`.
RADISH_FRONTEND_IMAGE=ghcr.io/your-org/radish-frontend:v26.3.1-release
RADISH_API_IMAGE=ghcr.io/your-org/radish-api:v26.3.1-release
RADISH_AUTH_IMAGE=ghcr.io/your-org/radish-auth:v26.3.1-release
RADISH_GATEWAY_IMAGE=ghcr.io/your-org/radish-gateway:v26.3.1-release

# Public HTTPS URL exposed by the reverse proxy and used as the frontend runtime fallback origin.
RADISH_PUBLIC_URL=https://radish.example.com

# Host directory mounted into the auth and api containers as /app/certs.
RADISH_AUTH_CERTS_DIR=/etc/radish/certs

# OIDC certificates used by Radish.Auth inside the container.
# The signing certificate is also reused by Radish.Api for local JWT validation.
# When files are missing, the auth container can generate them into RADISH_AUTH_CERTS_DIR on first start.
RADISH_AUTH_CERT_AUTO_GENERATE=true
RADISH_AUTH_CERT_VALID_DAYS=730
RADISH_AUTH_SIGNING_CERT_PATH=/app/certs/auth-signing.pfx
RADISH_AUTH_SIGNING_CERT_PASSWORD=ChangeMeSigning123!
RADISH_AUTH_ENCRYPTION_CERT_PATH=/app/certs/auth-encryption.pfx
RADISH_AUTH_ENCRYPTION_CERT_PASSWORD=ChangeMeEncryption123!

# Optional minimal production overrides.
# Redis__Enable=false
# Snowflake__WorkId=1

# Optional frontend runtime overrides.
# When omitted, the frontend container will fall back to RADISH_PUBLIC_URL.
# VITE_API_BASE_URL=https://radish.example.com
# VITE_AUTH_BASE_URL=https://radish.example.com
# VITE_SIGNALR_HUB_URL=https://radish.example.com
# VITE_AUTH_SERVER_URL=https://radish.example.com
