# Copy this file to Deploy/.env.test and replace the example values before rollout.

# Public HTTPS entry used for test deployment.
# For direct IP access, keep this value aligned with the mapped Gateway port below.
RADISH_PUBLIC_URL=https://127.0.0.1:5000
RADISH_GATEWAY_HTTPS_PORT=5000

# Gateway self-signed TLS certificate settings.
RADISH_GATEWAY_CERT_AUTO_GENERATE=true
RADISH_GATEWAY_CERT_PASSWORD=ChangeMeGateway123!
RADISH_GATEWAY_CERT_VALID_DAYS=365

# Auth OIDC signing / encryption certificates.
RADISH_AUTH_CERT_AUTO_GENERATE=true
RADISH_AUTH_CERT_VALID_DAYS=365
RADISH_AUTH_SIGNING_CERT_PASSWORD=ChangeMeSigning123!
RADISH_AUTH_ENCRYPTION_CERT_PASSWORD=ChangeMeEncryption123!

# Optional frontend runtime overrides.
# When omitted, the frontend container will fall back to RADISH_PUBLIC_URL.
# VITE_API_BASE_URL=https://127.0.0.1:5000
# VITE_AUTH_BASE_URL=https://127.0.0.1:5000
# VITE_SIGNALR_HUB_URL=https://127.0.0.1:5000
# VITE_AUTH_SERVER_URL=https://127.0.0.1:5000
