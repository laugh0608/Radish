{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Radish",
  "version": "0.1.0",
  "identifier": "com.radish.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../../Frontend/radish.client/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Radish",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/icon.png"]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["radish"]
      }
    }
  }
}
