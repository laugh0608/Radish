{
  "name": "radish-root",
  "private": true,
  "version": "26.1.1",
  "workspaces": [
    "Frontend/radish.http",
    "Frontend/radish.client",
    "Frontend/radish.console",
    "Frontend/radish.ui"
  ],
  "scripts": {
    "check:console-permissions": "node Scripts/check-console-permissions.mjs",
    "dev:frontend": "npm run dev --workspace=radish.client",
    "dev:console": "npm run dev --workspace=radish.console",
    "dev:gateway": "dotnet run --project Radish.Gateway/Radish.Gateway.csproj",
    "dev:api": "dotnet run --project Radish.Api/Radish.Api.csproj",
    "type-check": "npm run type-check --workspace=@radish/ui && npm run type-check --workspace=radish.client && npm run type-check --workspace=radish.console",
    "type-check:ui": "npm run type-check --workspace=@radish/ui",
    "type-check:client": "npm run type-check --workspace=radish.client",
    "type-check:console": "npm run type-check --workspace=radish.console",
    "install:all": "npm install"
  }
}
