@Access_Token = 在这里粘贴通过 OIDC 获取的 access_token
@Gateway_HostAddress = https://localhost:5000

@TargetUserId = 20002
@ReportTargetPostId = 1
@ReviewReportId = 1
@ReportPublicId = rpt_replace_me
@ModerationCasePublicId = mod_replace_me

### 关注用户
POST {{Gateway_HostAddress}}/api/v1/UserFollow/Follow
Content-Type: application/json
Authorization: Bearer {{Access_Token}}

{
  "targetUserId": {{TargetUserId}}
}

### 获取我的举报结果
GET {{Gateway_HostAddress}}/api/v1/ContentModeration/GetMyReports?pageIndex=1&pageSize=20
Accept: application/json
Authorization: Bearer {{Access_Token}}

### 获取我的单份举报结果
GET {{Gateway_HostAddress}}/api/v1/ContentModeration/GetMyReport/{{ReportPublicId}}
Accept: application/json
Authorization: Bearer {{Access_Token}}

### 获取关注状态
GET {{Gateway_HostAddress}}/api/v1/UserFollow/GetFollowStatus?targetUserId={{TargetUserId}}
Accept: application/json
Authorization: Bearer {{Access_Token}}

### 获取我的粉丝列表
GET {{Gateway_HostAddress}}/api/v1/UserFollow/GetMyFollowers?pageIndex=1&pageSize=10
Accept: application/json
Authorization: Bearer {{Access_Token}}

### 获取我的关注列表
GET {{Gateway_HostAddress}}/api/v1/UserFollow/GetMyFollowing?pageIndex=1&pageSize=10
Accept: application/json
Authorization: Bearer {{Access_Token}}

### 获取我的关系链动态流
GET {{Gateway_HostAddress}}/api/v1/UserFollow/GetMyFollowingFeed?pageIndex=1&pageSize=10
Accept: application/json
Authorization: Bearer {{Access_Token}}

### 获取我的分发流（推荐）
GET {{Gateway_HostAddress}}/api/v1/UserFollow/GetMyDistributionFeed?streamType=recommend&pageIndex=1&pageSize=10
Accept: application/json
Authorization: Bearer {{Access_Token}}

### 获取我的分发流（热门）
GET {{Gateway_HostAddress}}/api/v1/UserFollow/GetMyDistributionFeed?streamType=hot&pageIndex=1&pageSize=10
Accept: application/json
Authorization: Bearer {{Access_Token}}

### 获取我的分发流（最新）
GET {{Gateway_HostAddress}}/api/v1/UserFollow/GetMyDistributionFeed?streamType=newest&pageIndex=1&pageSize=10
Accept: application/json
Authorization: Bearer {{Access_Token}}

### 获取我的分发流（非法 streamType，预期 400）
GET {{Gateway_HostAddress}}/api/v1/UserFollow/GetMyDistributionFeed?streamType=timeline&pageIndex=1&pageSize=10
Accept: application/json
Authorization: Bearer {{Access_Token}}

### 取消关注用户
POST {{Gateway_HostAddress}}/api/v1/UserFollow/Unfollow
Content-Type: application/json
Authorization: Bearer {{Access_Token}}

{
  "targetUserId": {{TargetUserId}}
}

### 提交帖子举报
POST {{Gateway_HostAddress}}/api/v1/ContentModeration/Report
Content-Type: application/json
Authorization: Bearer {{Access_Token}}

{
  "targetType": "Post",
  "targetContentId": {{ReportTargetPostId}},
  "reasonType": "Spam",
  "reasonDetail": "疑似广告灌水"
}

### 获取我的治理状态
GET {{Gateway_HostAddress}}/api/v1/ContentModeration/GetMyModerationStatus
Accept: application/json
Authorization: Bearer {{Access_Token}}

### 获取我的发布权限
GET {{Gateway_HostAddress}}/api/v1/ContentModeration/GetMyPublishPermission
Accept: application/json
Authorization: Bearer {{Access_Token}}

### 管理端：获取举报审核队列
GET {{Gateway_HostAddress}}/api/v1/ContentModeration/GetReviewQueue?status=0&pageIndex=1&pageSize=10
Accept: application/json
Authorization: Bearer {{Access_Token}}

### 管理端：获取治理案件队列
GET {{Gateway_HostAddress}}/api/v1/ContentModeration/GetCaseQueue?status=0&pageIndex=1&pageSize=20
Accept: application/json
Authorization: Bearer {{Access_Token}}

### 管理端：获取治理案件详情
GET {{Gateway_HostAddress}}/api/v1/ContentModeration/GetCase/{{ModerationCasePublicId}}
Accept: application/json
Authorization: Bearer {{Access_Token}}

### 管理端：追加当前目标快照
POST {{Gateway_HostAddress}}/api/v1/ContentModeration/CaptureEvidence
Content-Type: application/json
Authorization: Bearer {{Access_Token}}

{
  "casePublicId": "{{ModerationCasePublicId}}",
  "expectedVersion": 1,
  "evidenceType": 2
}

### 管理端：登记违规决定、限制目标并禁言
POST {{Gateway_HostAddress}}/api/v1/ContentModeration/ReviewCase
Content-Type: application/json
Authorization: Bearer {{Access_Token}}

{
  "casePublicId": "{{ModerationCasePublicId}}",
  "expectedVersion": 2,
  "decision": 2,
  "targetDisposition": 2,
  "expectedTargetVersion": 0,
  "publicResultCode": "MeasuresTaken",
  "internalRemark": "证据确认违规",
  "userAction": {
    "actionType": 1,
    "expectedStateVersion": 0,
    "durationHours": 24,
    "reason": "违规内容处置"
  },
  "operationKey": "moderation-case-demo-001"
}

### 管理端：审核举报并禁言 24 小时
POST {{Gateway_HostAddress}}/api/v1/ContentModeration/Review
Content-Type: application/json
Authorization: Bearer {{Access_Token}}

{
  "reportId": {{ReviewReportId}},
  "isApproved": true,
  "actionType": 1,
  "durationHours": 24,
  "reviewRemark": "违规灌水，禁言 24 小时"
}

### 管理端：手动封禁用户
POST {{Gateway_HostAddress}}/api/v1/ContentModeration/ApplyUserAction
Content-Type: application/json
Authorization: Bearer {{Access_Token}}

{
  "targetUserId": {{TargetUserId}},
  "actionType": 2,
  "reason": "多次发布违规内容"
}

### 管理端：手动解除禁言
POST {{Gateway_HostAddress}}/api/v1/ContentModeration/ApplyUserAction
Content-Type: application/json
Authorization: Bearer {{Access_Token}}

{
  "targetUserId": {{TargetUserId}},
  "actionType": 3,
  "reason": "人工复核后解除禁言"
}

### 管理端：获取治理动作记录
GET {{Gateway_HostAddress}}/api/v1/ContentModeration/GetActionLogs?pageIndex=1&pageSize=10
Accept: application/json
Authorization: Bearer {{Access_Token}}

### 管理端：按举报单 / 动作类型 / 生效状态筛选治理动作记录
GET {{Gateway_HostAddress}}/api/v1/ContentModeration/GetActionLogs?pageIndex=1&pageSize=10&sourceReportId={{ReviewReportId}}&actionType=Mute&isActive=true&keyword=reviewer
Accept: application/json
Authorization: Bearer {{Access_Token}}

@ShopAdminProductId = 1
@ShopAdminOrderId = 1

### 管理端：获取商品详情
GET {{Gateway_HostAddress}}/api/v1/Shop/AdminGetProduct/{{ShopAdminProductId}}
Accept: application/json
Authorization: Bearer {{Access_Token}}

### 管理端：获取订单详情
GET {{Gateway_HostAddress}}/api/v1/Shop/AdminGetOrder/{{ShopAdminOrderId}}
Accept: application/json
Authorization: Bearer {{Access_Token}}

### 管理端：删除商品
DELETE {{Gateway_HostAddress}}/api/v1/Shop/DeleteProduct/{{ShopAdminProductId}}
Accept: application/json
Authorization: Bearer {{Access_Token}}
