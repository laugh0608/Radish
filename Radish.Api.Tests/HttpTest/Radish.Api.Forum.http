###############################################################################
# 分类管理 (Category)
###############################################################################

### 1. 获取所有顶级分类
GET {{Gateway_HostAddress}}/api/v1/Category/GetTopCategories
Accept: application/json

### 2. 获取指定分类的子分类（需要先有分类ID）
GET {{Gateway_HostAddress}}/api/v1/Category/GetChildCategories?parentId=80001
Accept: application/json

### 3. 根据ID获取分类详情
GET {{Gateway_HostAddress}}/api/v1/Category/GetById/80001
Accept: application/json

### 4. 创建新分类（需要认证）
POST {{Gateway_HostAddress}}/api/v1/Category/Create
Content-Type: application/json
Authorization: Bearer {{Access_Token}}

{
  "name": "测试分类",
  "slug": "test-category",
  "description": "这是一个测试分类",
  "icon": "🧪",
  "sortOrder": 100,
  "isEnabled": true,
  "isDeleted": false,
  "parentId": null
}

###############################################################################
# 标签管理 (Tag)
###############################################################################

### 5. 获取所有标签
GET {{Gateway_HostAddress}}/api/v1/Tag/GetAll
Accept: application/json

### 6. 获取热门标签（默认前20个）
GET {{Gateway_HostAddress}}/api/v1/Tag/GetHotTags
Accept: application/json

### 7. 获取热门标签（指定数量）
GET {{Gateway_HostAddress}}/api/v1/Tag/GetHotTags?topCount=10
Accept: application/json

### 8. 根据ID获取标签详情
GET {{Gateway_HostAddress}}/api/v1/Tag/GetById/1
Accept: application/json

### 8.1 获取固定标签列表
GET {{Gateway_HostAddress}}/api/v1/Tag/GetFixedTags
Accept: application/json

### 8.2 管理端分页查询标签
GET {{Gateway_HostAddress}}/api/v1/Tag/GetPage?pageIndex=1&pageSize=10&isFixed=true
Accept: application/json
Authorization: Bearer {{Access_Token}}

### 8.3 管理端创建标签
POST {{Gateway_HostAddress}}/api/v1/Tag/Create
Content-Type: application/json
Authorization: Bearer {{Access_Token}}

{
  "name": "测试固定标签",
  "slug": "test-fixed-tag",
  "description": "测试用固定标签",
  "color": "#1677FF",
  "sortOrder": 99,
  "isEnabled": true,
  "isFixed": true
}

### 8.4 管理端更新标签
PUT {{Gateway_HostAddress}}/api/v1/Tag/Update/90104
Content-Type: application/json
Authorization: Bearer {{Access_Token}}

{
  "name": "公告",
  "slug": "notice",
  "description": "社区公告与通知",
  "color": "#F5222D",
  "sortOrder": 5,
  "isEnabled": true,
  "isFixed": true
}

### 8.5 管理端切换标签状态
PUT {{Gateway_HostAddress}}/api/v1/Tag/ToggleStatus/90103/status?enabled=true
Content-Type: application/json
Authorization: Bearer {{Access_Token}}

{}

### 8.6 管理端更新排序
PUT {{Gateway_HostAddress}}/api/v1/Tag/UpdateSort/90103/sort?sortOrder=4
Content-Type: application/json
Authorization: Bearer {{Access_Token}}

{}

### 8.7 管理端软删除标签
DELETE {{Gateway_HostAddress}}/api/v1/Tag/Delete/90103
Accept: application/json
Authorization: Bearer {{Access_Token}}

### 8.8 管理端恢复标签
PUT {{Gateway_HostAddress}}/api/v1/Tag/Restore/90103/restore
Content-Type: application/json
Authorization: Bearer {{Access_Token}}

{}

###############################################################################
# 帖子管理 (Post)
###############################################################################

### 9. 获取所有帖子列表
GET {{Gateway_HostAddress}}/api/v1/Post/GetList
Accept: application/json

### 10. 获取指定分类的帖子列表
GET {{Gateway_HostAddress}}/api/v1/Post/GetList?categoryId=80001
Accept: application/json

### 11. 根据ID获取帖子详情（会自动增加浏览次数）
GET {{Gateway_HostAddress}}/api/v1/Post/GetById/1
Accept: application/json

### 12. 发布新帖子（需要认证）
POST {{Gateway_HostAddress}}/api/v1/Post/Publish
Content-Type: application/json
Authorization: Bearer {{Access_Token}}

{
  "title": "我的第一篇测试帖子",
  "content": "这是帖子的内容，可以包含**Markdown**格式。\n\n## 二级标题\n\n- 列表项1\n- 列表项2",
  "categoryId": 1,
  "tagNames": ["C#", ".NET", "测试"],
  "isPublished": true
}

### 13. 发布帖子（最小化数据）
POST {{Gateway_HostAddress}}/api/v1/Post/Publish
Content-Type: application/json
Authorization: Bearer {{Access_Token}}

{
  "title": "简单测试帖子",
  "content": "简单的内容",
  "categoryId": 1,
  "isPublished": true
}

### 14. 更新帖子（需要认证）
PUT {{Gateway_HostAddress}}/api/v1/Post/Update
Content-Type: application/json
Authorization: Bearer {{Access_Token}}

{
  "postId": 1,
  "title": "更新后的标题",
  "content": "更新后的内容",
  "categoryId": 1
}

### 14.1 获取帖子编辑历史（分页）
GET {{Gateway_HostAddress}}/api/v1/Post/GetEditHistory?postId=1&pageIndex=1&pageSize=10
Accept: application/json
Authorization: Bearer {{Access_Token}}

###############################################################################
# 评论管理 (Comment)
###############################################################################

### 15. 获取帖子的评论树
GET {{Gateway_HostAddress}}/api/v1/Comment/GetCommentTree?postId=1999694582291365888
Accept: application/json

### 16. 发表根评论（直接评论帖子）
POST {{Gateway_HostAddress}}/api/v1/Comment/Create
Content-Type: application/json
Authorization: Bearer {{Access_Token}}

{
  "postId": 1999694582291365888,
  "content": "这是一条测试评论",
  "parentId": null,
  "replyToUserId": null,
  "replyToUserName": null
}

### 17. 发表回复评论（回复某条评论）
POST {{Gateway_HostAddress}}/api/v1/Comment/Create
Content-Type: application/json
Authorization: Bearer {{Access_Token}}

{
  "postId": 1,
  "content": "我来回复你的评论",
  "parentId": 1,
  "replyToUserId": 20000,
  "replyToUserName": "system"
}

### 18. 发表多级嵌套回复
POST {{Gateway_HostAddress}}/api/v1/Comment/Create
Content-Type: application/json
Authorization: Bearer {{Access_Token}}

{
  "postId": 1,
  "content": "这是第三层的回复",
  "parentId": 2,
  "replyToUserId": 20000,
  "replyToUserName": "system"
}

### 19. 更新评论内容（需要在5分钟内，且只能作者本人编辑）
PUT {{Gateway_HostAddress}}/api/v1/Comment/Update
Content-Type: application/json
Authorization: Bearer {{Access_Token}}

{
  "commentId": 1,
  "content": "这是修改后的评论内容"
}

### 20. 测试更新评论 - 超时场景（应该失败，如果评论已超过5分钟）
PUT {{Gateway_HostAddress}}/api/v1/Comment/Update
Content-Type: application/json
Authorization: Bearer {{Access_Token}}

{
  "commentId": 1999694582291365888,
  "content": "尝试修改超过5分钟的评论"
}

### 21. 测试更新评论 - 空内容（应该失败）
PUT {{Gateway_HostAddress}}/api/v1/Comment/Update
Content-Type: application/json
Authorization: Bearer {{Access_Token}}

{
  "commentId": 1,
  "content": ""
}

### 21.1 获取评论编辑历史（分页）
GET {{Gateway_HostAddress}}/api/v1/Comment/GetEditHistory?commentId=1&pageIndex=1&pageSize=10
Accept: application/json
Authorization: Bearer {{Access_Token}}

###############################################################################
# 综合测试场景
###############################################################################

### 场景1: 完整流程 - 创建分类 -> 发布帖子 -> 发表评论
# 步骤1: 创建分类（使用上面的"创建新分类"请求）
# 步骤2: 发布帖子（使用上面的"发布新帖子"请求）
# 步骤3: 查看帖子详情（使用"根据ID获取帖子详情"请求）
# 步骤4: 发表评论（使用"发表根评论"请求）
# 步骤5: 查看评论树（使用"获取帖子的评论树"请求）

### 场景2: 边界测试 - 查询不存在的资源
GET {{Gateway_HostAddress}}/api/v1/Category/GetById/999999
Accept: application/json

### 场景3: 边界测试 - 查询不存在的帖子
GET {{Gateway_HostAddress}}/api/v1/Post/GetById/999999
Accept: application/json

### 场景4: 边界测试 - 查询不存在的标签
GET {{Gateway_HostAddress}}/api/v1/Tag/GetById/999999
Accept: application/json

### 场景5: 错误测试 - 发布空内容的帖子（应该失败）
POST {{Gateway_HostAddress}}/api/v1/Post/Publish
Content-Type: application/json
Authorization: Bearer {{Access_Token}}

{
  "title": "",
  "content": "",
  "categoryId": 1,
  "isPublished": true
}

### 场景6: 错误测试 - 发表空内容的评论（应该失败）
POST {{Gateway_HostAddress}}/api/v1/Comment/Create
Content-Type: application/json
Authorization: Bearer {{Access_Token}}

{
  "postId": 1,
  "content": "",
  "parentId": null
}
